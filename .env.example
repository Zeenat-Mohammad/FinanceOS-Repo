VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_URL=http://localhost:5173

# Optional aliases accepted for users coming from Supabase's Next.js starter docs.
# In this Vite app, prefer the VITE_* names above.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Keep provider keys only in Supabase Edge Function secrets; never expose them to Vite.
# supabase secrets set FINNHUB_API_KEY=... OCR_SPACE_API_KEY=... NEWS_API_KEY=... ALPHA_VANTAGE_API_KEY=...
OPENAI_API_KEY=
